# TokTik Environment Variables
# Copy this to .env.local and fill in your values

# ── Supabase ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App URL (must match OAuth redirect URIs) ──────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── TikTok OAuth ──────────────────────────────────────────────────
# https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
NEXT_PUBLIC_TIKTOK_REDIRECT_URI=${NEXT_PUBLIC_APP_URL}/api/auth/tiktok/callback

# ── YouTube / Google OAuth ────────────────────────────────────────
# https://console.cloud.google.com/ → APIs & Services → Credentials
# Enable: YouTube Data API v3, Google People API
# Redirect URI: ${NEXT_PUBLIC_APP_URL}/api/auth/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Instagram & Facebook (Meta) OAuth ─────────────────────────────
# https://developers.facebook.com/ → App Dashboard
# Enable: Instagram Graph API, Facebook Pages API
# Redirect URIs:
#   ${NEXT_PUBLIC_APP_URL}/api/auth/instagram/callback
#   ${NEXT_PUBLIC_APP_URL}/api/auth/facebook/callback
META_APP_ID=
META_APP_SECRET=

# ── Twitter / X OAuth 2.0 ────────────────────────────────────────
# https://developer.twitter.com/en/portal/projects-and-apps
# OAuth 2.0 with PKCE enabled
# Redirect URI: ${NEXT_PUBLIC_APP_URL}/api/auth/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── LinkedIn OAuth 2.0 ───────────────────────────────────────────
# https://www.linkedin.com/developers/apps
# Products: Sign In with LinkedIn using OpenID Connect, Share on LinkedIn
# Redirect URI: ${NEXT_PUBLIC_APP_URL}/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Video Generation ──────────────────────────────────────────────
CREATOMATE_API_KEY=

# ── Credentials Encryption ────────────────────────────────────────
CREDENTIALS_ENC_KEY=change-this-to-a-long-random-secret-in-production

# ── Cron Job Protection ──────────────────────────────────────────
CRON_SECRET=
